/* app.wxss - 现代化美化版全局样式 */

/* 基础重置 */
page {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

view, text, image, navigator, button {
  box-sizing: border-box;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* 禁止文本选择 */
page {
  -webkit-user-select: none;
  user-select: none;
  -webkit-overflow-scrolling: touch;
}

/* 按钮重置 */
button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  line-height: inherit;
  font-size: inherit;
  font-weight: inherit;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

button::after {
  border: none;
}

/* 文本样式 */
text {
  display: inline;
}

/* 导航器样式 */
navigator {
  text-decoration: none;
  color: inherit;
  display: inline-flex;
  align-items: center;
}

/* 图片默认样式 */
image {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 阴影效果 */
.shadow-sm {
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.shadow-md {
  box-shadow: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1);
}

.shadow-lg {
  box-shadow: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1);
}

/* 圆角效果 */
.rounded-sm {
  border-radius: 8rpx;
}

.rounded-md {
  border-radius: 12rpx;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-xl {
  border-radius: 24rpx;
}

.rounded-2xl {
  border-radius: 32rpx;
}

/* 过渡动画 */
.transition-all {
  transition: all 0.3s ease;
}

/* 点击动画 */
.active:active {
  transform: scale(0.98);
}

/* 毛玻璃效果 */
.glass {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.glass-dark {
  background: rgba(30, 41, 59, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
}

.gradient-success {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.gradient-warning {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.gradient-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.gradient-info {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

/* 边框效果 */
.border-dashed {
  border-style: dashed;
}

.border-dotted {
  border-style: dotted;
}

/* 透明度效果 */
.opacity-0 {
  opacity: 0;
}

.opacity-50 {
  opacity: 0.5;
}

.opacity-75 {
  opacity: 0.75;
}

.opacity-100 {
  opacity: 1;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

/* Gap间距 */
.gap-2 {
  gap: 16rpx;
}

.gap-4 {
  gap: 32rpx;
}

.gap-8 {
  gap: 64rpx;
}

/* 内边距 */
.p-2 {
  padding: 16rpx;
}

.p-4 {
  padding: 32rpx;
}

.p-6 {
  padding: 48rpx;
}

.px-2 {
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.px-4 {
  padding-left: 32rpx;
  padding-right: 32rpx;
}

.py-2 {
  padding-top: 16rpx;
  padding-bottom: 16rpx;
}

.py-4 {
  padding-top: 32rpx;
  padding-bottom: 32rpx;
}

/* 外边距 */
.m-2 {
  margin: 16rpx;
}

.m-4 {
  margin: 32rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

/* 定位 */
.relative {
  position: relative;
}

.absolute {
  position: absolute;
}

.fixed {
  position: fixed;
}

/* 层级 */
.z-0 {
  z-index: 0;
}

.z-10 {
  z-index: 10;
}

.z-50 {
  z-index: 50;
}

.z-1000 {
  z-index: 1000;
}

.z-99999 {
  z-index: 99999;
}

/* 宽度 */
.w-full {
  width: 100%;
}

.max-w-full {
  max-width: 100%;
}

/* 高度 */
.h-full {
  height: 100%;
}

/* 溢出 */
.overflow-hidden {
  overflow: hidden;
}

/* 文本截断 */
.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 打字机动画 */
.typewriter {
  overflow: hidden;
  border-right: 2rpx solid #4f46e5;
  white-space: nowrap;
  animation: typing 3.5s steps(40, end), blink-caret 0.75s step-end infinite;
}

@keyframes typing {
  from { width: 0; }
  to { width: 100%; }
}

@keyframes blink-caret {
  from, to { border-color: transparent; }
  50% { border-color: #4f46e5; }
}

/* 加载动画 */
.loading {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(99, 102, 241, 0.1);
  border-top-color: #4f46e5;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 闪烁动画 */
.blink {
  animation: blink 1.5s step-end infinite;
}

@keyframes blink {
  50% { opacity: 0; }
}

/* 旋转动画 */
.rotate {
  animation: rotate 3s linear infinite;
}

@keyframes rotate {
  to { transform: rotate(360deg); }
}

/* 缩放动画 */
.bounce-in {
  animation: bounce-in 0.6s ease-out;
}

@keyframes bounce-in {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 浮动动画 */
.float {
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 弹跳动画 */
.bounce {
  animation: bounce 0.6s ease;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

/* 渐变背景动画 */
.gradient-animate {
  background-size: 200% 200%;
  animation: gradient-move 3s ease infinite;
}

@keyframes gradient-move {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}