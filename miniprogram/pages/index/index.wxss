/* 超小屏幕优化 */
@media (max-width: 380px) {
  .page-container {
    padding: 24rpx;
    padding-bottom: 180rpx;
  }

  .card {
    padding: 40rpx 32rpx;
  }

  .resource-title {
    font-size: 32rpx;
  }

