/* pages/index/index.wxss */
/* 移动端优先样式 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background: #f5f7fb;
  color: #1e293b;
  min-height: 100vh;
  font-size: 28rpx;
  line-height: 1.6;
}

.page-container {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* ==================== 顶部Logo ==================== */
.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.site-logo {
  width: 48rpx;
  height: 48rpx;
  object-fit: contain;
}

.site-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

/* ==================== 主舞台 ==================== */
.stage {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ==================== 卡片 ==================== */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #4f46e5, #7c3aed, #ec4899);
}

.resource-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.4;
}

.extract-code {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #eff6ff, #e0e7ff);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid rgba(79, 70, 229, 0.1);
}

.extract-code text:first-child {
  font-size: 26rpx;
  color: #475569;
}

.code-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #4f46e5;
}

.sub-text {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  display: block;
  line-height: 1.6;
}

.app-name {
  color: #4f46e5;
  font-weight: 600;
}

/* ==================== 二维码 ==================== */
.qr {
  width: 280rpx;
  height: 280rpx;
  margin: 24rpx auto;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.15);
  border: 4rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.qr::before {
  content: '';
  position: absolute;
  inset: 8rpx;
  border: 2rpx solid rgba(79, 70, 229, 0.15);
  border-radius: 16rpx;
}

.qr-canvas {
  width: 252rpx;
  height: 252rpx;
}

.hint {
  text-align: center;
  margin-top: 24rpx;
}

.hint text:first-child {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  display: block;
  margin-bottom: 8rpx;
}

.hint-small {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
}

.highlight {
  color: #4f46e5;
  font-weight: 600;
}

/* ==================== 卡片内推广 ==================== */
.card-promo {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #e2e8f0;
  text-align: center;
}

.card-promo navigator {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #eff6ff, #e0e7ff);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #4f46e5;
  font-weight: 500;
}

/* ==================== 引导图 ==================== */
.guide-right {
  display: none;
}

/* ==================== 错误页面 ==================== */
.error-container {
  background: #fff;
  border-radius: 24rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.error-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #ef4444, #f87171, #fca5a5);
}

.error-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ef4444;
  margin-bottom: 12rpx;
  display: block;
}

.error-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 32rpx;
  display: block;
}

.error-promo {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #e2e8f0;
}

.error-promo-text {
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 16rpx;
  display: block;
  line-height: 1.6;
}

.error-promo-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

/* ==================== 底部推广条 ==================== */
.page-promo {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 100;
  box-shadow: 0 -4rpx 20rpx rgba(79, 70, 229, 0.2);
}

.page-promo-text {
  flex: 1;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
}

.page-promo-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  color: #4f46e5;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 32rpx;
  white-space: nowrap;
}

/* ==================== 免责声明 ==================== */
.disclaimer {
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid #e2e8f0;
}

.disclaimer-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  display: block;
  margin-bottom: 8rpx;
}

.disclaimer-content {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  line-height: 1.6;
}

/* ==================== 广告弹窗 ==================== */
.ad-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99999;
  transition: opacity 0.5s ease;
}

.ad-overlay.theme-gradient {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.ad-overlay.theme-sunset {
  background: linear-gradient(135deg, #f093fb, #f5576c, #f6d365);
}

.ad-overlay.theme-ocean {
  background: linear-gradient(135deg, #0c3483, #a2b6df, #6b8dd6);
}

.ad-overlay.theme-forest {
  background: linear-gradient(135deg, #134e5e, #71b280);
}

.ad-overlay.theme-dark {
  background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
}

.ad-overlay.theme-candy {
  background: linear-gradient(135deg, #a8edea, #fed6e3, #d299c2);
}

.ad-bg-animation {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.ad-bg-animation .circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  animation: float 8s ease-in-out infinite;
}

.ad-bg-animation .circle:nth-child(1) {
  width: 400rpx;
  height: 400rpx;
  left: -100rpx;
  top: -100rpx;
}

.ad-bg-animation .circle:nth-child(2) {
  width: 300rpx;
  height: 300rpx;
  right: -50rpx;
  top: 30%;
  animation-delay: -2s;
}

.ad-bg-animation .circle:nth-child(3) {
  width: 350rpx;
  height: 350rpx;
  left: 20%;
  bottom: -100rpx;
  animation-delay: -4s;
}

.ad-bg-animation .circle:nth-child(4) {
  width: 200rpx;
  height: 200rpx;
  right: 20%;
  bottom: 20%;
  animation-delay: -6s;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.1; }
  50% { transform: translateY(-30rpx) scale(1.1); opacity: 0.2; }
}

.ad-container {
  position: relative;
  z-index: 1;
  width: 90%;
  max-width: 600rpx;
}

.ad-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(40px);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.ad-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.ad-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ad-disk {
  width: 200rpx;
  height: 60rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 2rpx solid #e2e8f0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ad-disk-img {
  width: 180rpx;
  height: 50rpx;
  object-fit: contain;
}

.ad-notice {
  padding: 6rpx 12rpx;
  background: #fee2e2;
  color: #ef4444;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 8rpx;
  border: 2rpx solid rgba(239, 68, 68, 0.2);
}

.ad-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.ad-countdown-wrapper {
  margin-bottom: 20rpx;
}

.ad-countdown {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #475569;
}

.ad-countdown-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #4f46e5;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ad-progress {
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.ad-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #4f46e5, #7c3aed);
  border-radius: 4rpx;
  transition: width 0.1s linear;
}

.ad-hint {
  font-size: 22rpx;
  color: #64748b;
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  line-height: 1.5;
  border: 2rpx solid #e2e8f0;
}

.ad-skip-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.4);
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.3s ease;
}

.ad-skip-btn.visible {
  opacity: 1;
  transform: translateY(0);
}

.ad-skip-btn::after {
  border: none;
}

.ad-generate-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #f8fafc;
  color: #4f46e5;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: 2rpx solid rgba(79, 70, 229, 0.2);
  margin-top: 16rpx;
}

.ad-decoration {
  position: absolute;
  pointer-events: none;
}

.ad-decoration.sparkle {
  width: 24rpx;
  height: 24rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.9), transparent);
  animation: sparkle 2s ease-in-out infinite;
}

.ad-decoration.sparkle:nth-child(1) {
  top: 15%;
  left: 10%;
}

.ad-decoration.sparkle:nth-child(2) {
  top: 25%;
  right: 15%;
  animation-delay: 0.5s;
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 1; transform: scale(1); }
}

.promo-link {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
  text-align: center;
}

.promo-link navigator {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}