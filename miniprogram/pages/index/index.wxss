    justify-content: center;
    gap: 24rpx;
    padding: 16rpx 0;
    margin-bottom: 32rpx;
  }

  .site-logo {
    height: 56rpx;
    width: 56rpx;
  }

  .site-name {
    font-size: 28rpx;
  }

  /* 主舞台优化 */
  .stage {
    flex-direction: column;
    gap: 40rpx;
    margin-top: 32rpx;
    padding: 0;
  }

  /* 卡片优化 */
