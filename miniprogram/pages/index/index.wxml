<!--pages/index/index.wxml-->
<view class="page-container" style="background: {{bgColor}}; padding-bottom: {{isMobile ? '160rpx' : '80rpx'}};">
  
  <!-- 广告弹窗 -->
  <view class="ad-overlay {{adThemeClass}}" wx:if="{{showAd}}" style="opacity: {{adOpacity}};">
    <!-- 动态背景 -->
    <view class="ad-bg-animation" wx:if="{{!isMobile}}">
      <view class="circle"></view>
      <view class="circle"></view>
      <view class="circle"></view>
      <view class="circle"></view>
    </view>
    
    <!-- 装饰元素 -->
    <view class="ad-decoration sparkle" wx:if="{{!isMobile}}"></view>
    <view class="ad-decoration sparkle" wx:if="{{!isMobile}}"></view>
    
    <view class="ad-container">
      <view class="ad-card">
        <view class="ad-header">
          <view class="ad-left">
            <view class="ad-disk">
              <image wx:if="{{diskLogo}}" src="{{diskLogo}}" mode="aspectFit" class="ad-disk-img"></image>
            </view>
          </view>
          <view class="ad-notice">广告内容</view>
        </view>
        
        <view class="ad-text">{{adText}}</view>
        
        <view class="ad-countdown-wrapper">
          <view class="ad-countdown">
            <text>即将跳转</text>
            <text class="ad-countdown-num">{{adCountdown}}</text>
            <text>秒</text>
          </view>
        </view>
        
        <view class="ad-progress">
          <view class="ad-progress-bar" style="width: {{progressWidth}}%;"></view>
        </view>
        
        <view class="ad-hint">{{adHint}}</view>
        
        <button class="ad-skip-btn {{showSkipBtn ? 'visible' : ''}}" bindtap="skipAd">
          <text>⏭️</text>
          <text>{{skipBtnText}}</text>
        </button>
        
        <navigator url="/pages/generator/generator" class="ad-generate-btn" open-type="navigate" wx:if="{{isMobile}}">
          <text>🔗</text>
          <text>免费生成链接</text>
        </navigator>
        
        <!-- 底部推广链接（桌面端） -->
        <view class="promo-link" wx:if="{{!isMobile}}">
          <navigator url="/pages/generator/generator" open-type="navigate">
            <text>🔗</text>
            <text>免费生成分享链接</text>
            <text>→</text>
          </navigator>
        </view>
      </view>
    </view>
  </view>

  <!-- 顶部Logo -->
  <view class="topbar">
    <image wx:if="{{diskLogo}}" src="{{diskLogo}}" class="site-logo" mode="aspectFit"></image>
    <view wx:else class="site-logo-placeholder"></view>
    <text class="site-name">{{diskName}}</text>
  </view>

  <!-- 主内容 -->
  <view class="stage">
    <!-- 二维码卡片 -->
    <view class="card" wx:if="{{showCard}}">
      <text class="resource-title">资源名称：{{resourceName}}</text>
      <view class="extract-code">
        <text>提取码：</text>
        <text class="code-value">{{extractCode}}</text>
      </view>
      <text class="sub-text">打开 <text class="app-name">{{appName}}</text> - 点击搜索框相机 - 扫码</text>
      <view class="qr" bindtap="copyLink">
        <canvas type="2d" id="qrcode" class="qr-canvas"></canvas>
      </view>
      <view class="hint">
        <text>由于资源仅允许手机端访问</text>
        <text class="hint-small">请使用 <text class="highlight">{{appName}}</text> 或浏览器扫码打开</text>
      </view>
      <view class="card-promo">
        <navigator url="/pages/generator/generator" open-type="navigate">
          <text>✨</text>
          <text>我也要生成分享链接</text>
        </navigator>
      </view>
    </view>

    <!-- 引导图（桌面端显示） -->
    <view class="guide-right" wx:if="{{showGuide && !isMobile}}">
      <image src="{{guideImage}}" class="guide-img" mode="aspectFit"></image>
    </view>

    <!-- 错误页面 -->
    <view class="error-container" wx:if="{{showError}}">
      <text class="error-icon">😕</text>
      <text class="error-title">{{errorMessage}}</text>
      <text class="error-desc">请检查链接是否完整或联系分享者重新获取</text>
      <view class="error-promo">
        <text class="error-promo-text">想要分享自己的资源？担心不是有效分享？试试这款转链工具让用户只能移动端打开，让每次分享都有效</text>
        <navigator url="/pages/generator/generator" class="error-promo-btn" open-type="navigate">
          <text>🔗</text>
          <text>免费生成分享链接</text>
        </navigator>
      </view>
    </view>
  </view>

  <!-- 底部推广条 -->
  <view class="page-promo">
    <text class="page-promo-text">📢 想要分享自己的资源？担心不是有效分享？试试这款转链工具让用户只能移动端打开，让每次分享都有效</text>
    <navigator url="/pages/generator/generator" class="page-promo-btn" open-type="navigate">
      <text>🔗</text>
      <text>免费生成链接</text>
    </navigator>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer">
    <text class="disclaimer-title">⚠️ 免责声明</text>
    <text class="disclaimer-content">本页面仅提供链接跳转服务，不存储任何资源文件。所有资源均由第三方网盘托管，本站不对资源内容的合法性、准确性、安全性负责。</text>
    <text class="disclaimer-content">用户应自行判断资源的合法性，因使用本服务产生的任何法律责任由用户自行承担。如有侵权，请联系资源分享者删除。</text>
  </view>
</view>