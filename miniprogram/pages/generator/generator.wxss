/* pages/generator/generator.wxss */
/* 移动端优先样式 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background: #f5f7fb;
  min-height: 100vh;
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* ==================== 头部 ==================== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.header-left {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.header-subtitle {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  padding: 0;
  margin: 0;
}

.icon-btn::after {
  border: none;
}

/* ==================== 标签页 ==================== */
.tabs {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-inner {
  display: flex;
  gap: 8rpx;
}

.tab {
  flex: 1;
  min-width: 120rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #64748b;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.tab.active {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.4);
}

/* ==================== 说明面板 ==================== */
.guide-panel {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(79, 70, 229, 0.1);
}

.guide-header {
  margin-bottom: 24rpx;
}

.guide-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.guide-subtitle {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.guide-steps {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.guide-step {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 24rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 4rpx;
}

.step-desc {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}

.guide-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

/* ==================== 面板 ==================== */
.panel {
  display: none;
}

.panel.active {
  display: block;
}

/* ==================== 表单 ==================== */
.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.required {
  color: #ef4444;
}

.label-hint {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 400;
}

.input-wrapper {
  display: flex;
  gap: 12rpx;
}

.input-wrapper .input {
  flex: 1;
}

.paste-btn {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #4f46e5;
  font-weight: 500;
}

.paste-btn::after {
  border: none;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1e293b;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1e293b;
  box-sizing: border-box;
}

.batch-textarea {
  min-height: 240rpx;
  font-family: ui-monospace, monospace;
  font-size: 24rpx;
}

.picker-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #1e293b;
}

.picker-arrow {
  font-size: 20rpx;
  color: #94a3b8;
}

/* ==================== 广告设置 ==================== */
.ad-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
}

.ad-toggle-left {
  flex: 1;
}

.ad-toggle-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
}

.ad-toggle-desc {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-top: 4rpx;
}

.ad-switch {
  transform: scale(0.8);
}

.ad-settings {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
}

.ad-textarea {
  min-height: 80rpx;
}

/* ==================== 按钮 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  color: #fff;
}

.btn-secondary {
  background: #f8fafc;
  color: #4f46e5;
  border: 2rpx solid rgba(79, 70, 229, 0.2);
}

.btn-success {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
}

.btn-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #fff;
}

.btn-sm {
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.btn-block {
  width: 100%;
}

.btn-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-group .btn {
  flex: 1;
}

/* ==================== 帮助卡片 ==================== */
.help-card {
  background: linear-gradient(135deg, rgba(79, 70, 229, 0.08), rgba(124, 58, 237, 0.06));
  border: 2rpx solid rgba(79, 70, 229, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.help-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.help-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.help-item {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
}

.help-example {
  background: #fff;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #64748b;
}

.example-text {
  color: #4f46e5;
  font-family: ui-monospace, monospace;
  word-break: break-all;
}

/* ==================== 结果卡片 ==================== */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(16, 185, 129, 0.2);
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(5, 150, 105, 0.08));
  border-bottom: 2rpx solid rgba(16, 185, 129, 0.2);
}

.result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #059669;
}

.btn-close {
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.1);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #64748b;
  padding: 0;
  margin: 0;
}

.btn-close::after {
  border: none;
}

.result-body {
  padding: 32rpx;
}

.result-item {
  margin-bottom: 24rpx;
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
  display: block;
  margin-bottom: 12rpx;
}

.result-url-box {
  background: #f8fafc;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e2e8f0;
}

.result-url {
  font-size: 24rpx;
  color: #1e293b;
  word-break: break-all;
  line-height: 1.6;
}

.qr-box {
  display: flex;
  justify-content: center;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
}

.result-qr {
  width: 320rpx;
  height: 320rpx;
}

/* ==================== 批量结果 ==================== */
.batch-result {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.batch-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.batch-result-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #059669;
}

.batch-list {
  max-height: 800rpx;
}

.batch-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid #e2e8f0;
}

.batch-item-index {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 22rpx;
  flex-shrink: 0;
}

.batch-item-info {
  flex: 1;
  min-width: 0;
}

.batch-item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.batch-item-url {
  font-size: 22rpx;
  color: #64748b;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.btn-copy {
  height: 56rpx;
  padding: 0 16rpx;
  background: #fff;
  border: 2rpx solid #4f46e5;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #4f46e5;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.btn-copy::after {
  border: none;
}

.btn-del {
  width: 48rpx;
  height: 48rpx;
  background: rgba(239, 68, 68, 0.1);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ef4444;
  padding: 0;
  margin: 0;
  flex-shrink: 0;
}

.btn-del::after {
  border: none;
}

/* ==================== 上传 ==================== */
.upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  background: #fff;
  border: 4rpx dashed #e2e8f0;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #94a3b8;
}

.file-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.file-icon {
  font-size: 48rpx;
}

.file-name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.import-result {
  text-align: center;
  padding: 48rpx;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(5, 150, 105, 0.08));
  border-radius: 20rpx;
  border: 2rpx solid rgba(16, 185, 129, 0.2);
}

.import-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #059669;
  display: block;
  margin-bottom: 8rpx;
}

.import-count {
  font-size: 26rpx;
  color: #475569;
}

/* ==================== 历史记录 ==================== */
.history-header {
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #1e293b;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.history-list {
  max-height: 1200rpx;
}

.history-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.history-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.history-item-index {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 22rpx;
  flex-shrink: 0;
}

.history-item-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-item-body {
  margin-bottom: 12rpx;
}

.history-item-url {
  font-size: 22rpx;
  color: #64748b;
  word-break: break-all;
  line-height: 1.6;
}

.history-item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-item-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* ==================== 设置 ==================== */
.settings-group {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.settings-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
  display: block;
}

.settings-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-label {
  font-size: 26rpx;
  color: #475569;
}

.settings-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #1e293b;
}

.group-add {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.group-add .input {
  flex: 1;
}

.group-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.group-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 2rpx solid #e2e8f0;
}

.group-item-name {
  font-size: 24rpx;
  color: #475569;
}

.settings-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.settings-actions .btn {
  flex: 1;
}

/* ==================== 底部推广条 ==================== */
.page-promo {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  z-index: 100;
  box-shadow: 0 -4rpx 20rpx rgba(79, 70, 229, 0.2);
}

.page-promo-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  flex: 1;
  line-height: 1.5;
}

.page-promo-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #fff;
  color: #4f46e5;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}