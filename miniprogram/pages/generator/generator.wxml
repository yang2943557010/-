<!--pages/generator/generator.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-left">
      <view class="header-title">🔗 链接生成器</view>
      <view class="header-subtitle">网盘资源分享链接生成</view>
    </view>
    <view class="header-actions">
      <button class="icon-btn" bindtap="toggleGuide">
        <text>💡</text>
      </button>
      <button class="icon-btn" bindtap="showShortcuts">
        <text>⌨️</text>
      </button>
    </view>
  </view>

  <!-- 标签页 -->
  <view class="tabs">
    <scroll-view scroll-x class="tabs-scroll">
      <view class="tabs-inner">
        <view class="tab {{activeTab === 'single' ? 'active' : ''}}" data-tab="single" bindtap="switchTab">
          <text>单个生成</text>
        </view>
        <view class="tab {{activeTab === 'batch' ? 'active' : ''}}" data-tab="batch" bindtap="switchTab">
          <text>批量生成</text>
        </view>
        <view class="tab {{activeTab === 'upload' ? 'active' : ''}}" data-tab="upload" bindtap="switchTab">
          <text>表格导入</text>
        </view>
        <view class="tab {{activeTab === 'history' ? 'active' : ''}}" data-tab="history" bindtap="switchTab">
          <text>历史记录</text>
        </view>
        <view class="tab {{activeTab === 'settings' ? 'active' : ''}}" data-tab="settings" bindtap="switchTab">
          <text>设置</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 新手说明面板 -->
  <view class="guide-panel" wx:if="{{showGuide}}">
    <view class="guide-header">
      <view class="guide-title">
        <text>💡 新手快速上手</text>
      </view>
      <view class="guide-subtitle">把网盘原链接转换成分享页链接</view>
    </view>
    <view class="guide-steps">
      <view class="guide-step">
        <view class="step-num">1</view>
        <view class="step-content">
          <view class="step-title">粘贴链接</view>
          <view class="step-desc">把网盘分享链接粘贴到输入框</view>
        </view>
      </view>
      <view class="guide-step">
        <view class="step-num">2</view>
        <view class="step-content">
          <view class="step-title">填写信息</view>
          <view class="step-desc">输入资源名称，提取码自动识别</view>
        </view>
      </view>
      <view class="guide-step">
        <view class="step-num">3</view>
        <view class="step-content">
          <view class="step-title">生成链接</view>
          <view class="step-desc">点击按钮生成分享链接</view>
        </view>
      </view>
      <view class="guide-step">
        <view class="step-num">4</view>
        <view class="step-content">
          <view class="step-title">复制分享</view>
          <view class="step-desc">复制链接分享给朋友</view>
        </view>
      </view>
    </view>
    <view class="guide-actions">
      <button class="btn btn-secondary btn-sm" bindtap="fillExample">
        <text>填入示例</text>
      </button>
      <button class="btn btn-secondary btn-sm" bindtap="toggleGuide">
        <text>知道了</text>
      </button>
    </view>
  </view>

  <!-- 单个生成面板 -->
  <view class="panel {{activeTab === 'single' ? 'active' : ''}}">
    <view class="form-section">
      <view class="form-group">
        <view class="label">
          <text>目标链接</text>
          <text class="required">*</text>
        </view>
        <view class="input-wrapper">
          <input class="input" placeholder="粘贴网盘链接" value="{{targetUrl}}" bindinput="onUrlInput" />
          <button class="paste-btn" bindtap="pasteLink">
            <text>粘贴</text>
          </button>
        </view>
      </view>
      
      <view class="form-group">
        <view class="label">
          <text>资源名称</text>
        </view>
        <input class="input" placeholder="给资源起个名字" value="{{resourceName}}" bindinput="onNameInput" />
      </view>
      
      <view class="form-group">
        <view class="label">
          <text>提取码</text>
          <text class="label-hint">自动识别</text>
        </view>
        <input class="input" placeholder="自动识别" value="{{extractCode}}" bindinput="onCodeInput" />
      </view>
      
      <view class="form-group">
        <view class="label">
          <text>页面风格</text>
        </view>
        <picker mode="selector" range="{{styleOptions}}" value="{{styleIndex}}" bindchange="onStyleChange">
          <view class="picker-btn">
            <text>{{styleOptions[styleIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      
      <view class="form-group">
        <view class="label">
          <text>备注信息</text>
        </view>
        <textarea class="textarea" placeholder="添加备注（可选）" value="{{remarkText}}" bindinput="onRemarkInput" />
      </view>
      
      <!-- 广告设置 -->
      <view class="form-group">
        <view class="ad-toggle">
          <view class="ad-toggle-left">
            <text class="ad-toggle-title">📢 广告提示</text>
            <text class="ad-toggle-desc">手机端跳转前显示</text>
          </view>
          <switch class="ad-switch" checked="{{adEnabled}}" bindchange="toggleAdSwitch" />
        </view>
        <view class="ad-settings" wx:if="{{adEnabled}}">
          <view class="form-group">
            <view class="label">
              <text>广告文字</text>
            </view>
            <textarea class="textarea ad-textarea" placeholder="正在为您跳转..." value="{{adText}}" bindinput="onAdTextInput" />
          </view>
          <view class="form-group">
            <view class="label">
              <text>显示时长</text>
            </view>
            <picker mode="selector" range="{{durationOptions}}" value="{{adDurationIndex}}" bindchange="onAdDurationChange">
              <view class="picker-btn">
                <text>{{durationOptions[adDurationIndex]}}</text>
                <text class="picker-arrow">▼</text>
              </view>
            </picker>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 按钮组 -->
    <view class="btn-group">
      <button class="btn btn-primary" bindtap="generateSingle">
        <text>✨ 生成链接</text>
      </button>
      <button class="btn btn-secondary" bindtap="previewResult">
        <text>👁️ 预览</text>
      </button>
    </view>
    
    <!-- 生成结果 -->
    <view class="result-card" wx:if="{{showResult}}">
      <view class="result-header">
        <text class="result-title">🎉 生成成功</text>
        <button class="btn-close" bindtap="hideResult">✕</button>
      </view>
      <view class="result-body">
        <view class="result-item">
          <text class="result-label">分享链接</text>
          <view class="result-url-box">
            <text class="result-url" selectable>{{generatedUrl}}</text>
          </view>
          <button class="btn btn-primary btn-block" bindtap="copyLink">
            <text>复制链接</text>
          </button>
        </view>
        <view class="result-item">
          <text class="result-label">二维码</text>
          <view class="qr-box">
            <canvas type="2d" id="resultQr" class="result-qr"></canvas>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 批量生成面板 -->
  <view class="panel {{activeTab === 'batch' ? 'active' : ''}}">
    <view class="help-card">
      <view class="help-title">
        <text>📦 批量生成说明</text>
      </view>
      <view class="help-list">
        <view class="help-item">
          <text>• 一行一个资源</text>
        </view>
        <view class="help-item">
          <text>• 格式：链接|名称|提取码</text>
        </view>
        <view class="help-item">
          <text>• 只有链接必填</text>
        </view>
      </view>
      <view class="help-example">
        <text>示例：</text>
        <text class="example-text">https://pan.quark.cn/s/xxx|电影资源|1234</text>
      </view>
    </view>
    
    <view class="form-group">
      <view class="label">
        <text>批量输入</text>
      </view>
      <textarea class="textarea batch-textarea" placeholder="每行一条，格式：链接|名称|提取码" value="{{batchInput}}" bindinput="onBatchInput" />
    </view>
    
    <view class="btn-group">
      <button class="btn btn-primary" bindtap="generateBatch">
        <text>批量生成</text>
      </button>
      <button class="btn btn-secondary" bindtap="clearBatch">
        <text>清空</text>
      </button>
    </view>
    
    <!-- 批量结果 -->
    <view class="batch-result" wx:if="{{batchResults.length > 0}}">
      <view class="batch-result-header">
        <text class="batch-result-title">✅ 已生成 {{batchResults.length}} 个链接</text>
        <button class="btn btn-secondary btn-sm" bindtap="copyAllBatchLinks">
          <text>全部复制</text>
        </button>
      </view>
      <scroll-view class="batch-list" scroll-y>
        <view class="batch-item" wx:for="{{batchResults}}" wx:key="index">
          <view class="batch-item-index">
            <text>{{item.index}}</text>
          </view>
          <view class="batch-item-info">
            <text class="batch-item-name">{{item.name}}</text>
            <text class="batch-item-url">{{item.url}}</text>
          </view>
          <button class="btn-copy" bindtap="copyBatchLink" data-index="{{index}}">
            <text>复制</text>
          </button>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 表格导入面板 -->
  <view class="panel {{activeTab === 'upload' ? 'active' : ''}}">
    <view class="upload-zone" bindtap="chooseFile" wx:if="{{!selectedFile}}">
      <text class="upload-icon">📊</text>
      <text class="upload-text">点击上传文件</text>
      <text class="upload-hint">支持 Excel / CSV 格式</text>
    </view>
    
    <view class="file-card" wx:if="{{selectedFile}}">
      <text class="file-icon">📄</text>
      <text class="file-name">{{selectedFile.name}}</text>
      <button class="btn btn-primary btn-sm" bindtap="uploadFile">导入</button>
      <button class="btn btn-secondary btn-sm" bindtap="clearFile">清空</button>
    </view>
    
    <view class="import-result" wx:if="{{importResults.length > 0}}">
      <text class="import-title">✅ 导入完成</text>
      <text class="import-count">共 {{importResults.length}} 条记录</text>
    </view>
  </view>

  <!-- 历史记录面板 -->
  <view class="panel {{activeTab === 'history' ? 'active' : ''}}">
    <view class="history-header">
      <input class="search-input" placeholder="🔍 搜索..." value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>
    
    <scroll-view class="history-list" scroll-y wx:if="{{historyList.length > 0}}">
      <view class="history-item" wx:for="{{historyList}}" wx:key="id">
        <view class="history-item-header">
          <text class="history-item-index">{{item.index}}</text>
          <text class="history-item-name">{{item.name}}</text>
          <button class="btn-del" bindtap="deleteHistory" data-id="{{item.id}}">✕</button>
        </view>
        <view class="history-item-body">
          <text class="history-item-url" selectable>{{item.url}}</text>
        </view>
        <view class="history-item-footer">
          <text class="history-item-time">{{item.time}}</text>
          <button class="btn-copy" bindtap="copyHistoryLink" data-id="{{item.id}}">复制</button>
        </view>
      </view>
    </scroll-view>
    
    <view class="empty-state" wx:if="{{historyList.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无历史记录</text>
    </view>
  </view>

  <!-- 设置面板 -->
  <view class="panel {{activeTab === 'settings' ? 'active' : ''}}">
    <view class="settings-group">
      <text class="settings-title">🎨 二维码样式</text>
      <view class="settings-item">
        <text class="settings-label">码点样式</text>
        <picker mode="selector" range="{{qrDotStyles}}" value="{{qrDotStyleIndex}}" bindchange="onQrDotStyleChange">
          <view class="settings-picker">
            <text>{{qrDotStyles[qrDotStyleIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="settings-item">
        <text class="settings-label">颜色模式</text>
        <picker mode="selector" range="{{qrColorModes}}" value="{{qrColorModeIndex}}" bindchange="onQrColorModeChange">
          <view class="settings-picker">
            <text>{{qrColorModes[qrColorModeIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="settings-item">
        <text class="settings-label">尺寸</text>
        <picker mode="selector" range="{{qrSizes}}" value="{{qrSizeIndex}}" bindchange="onQrSizeChange">
          <view class="settings-picker">
            <text>{{qrSizes[qrSizeIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
    
    <view class="settings-group">
      <text class="settings-title">🏷️ 自定义分组</text>
      <view class="group-add">
        <input class="input" placeholder="输入分组名称" value="{{newGroup}}" bindinput="onNewGroupInput" />
        <button class="btn btn-primary btn-sm" bindtap="addGroup">
          <text>添加</text>
        </button>
      </view>
      <view class="group-list" wx:if="{{customGroups.length > 0}}">
        <view class="group-item" wx:for="{{customGroups}}" wx:key="name">
          <text class="group-item-name">{{item.name}}</text>
          <button class="btn-del" bindtap="deleteGroup" data-index="{{index}}">✕</button>
        </view>
      </view>
    </view>
    
    <view class="settings-actions">
      <button class="btn btn-primary" bindtap="saveSettings">
        <text>保存设置</text>
      </button>
      <button class="btn btn-secondary" bindtap="resetSettings">
        <text>恢复默认</text>
      </button>
    </view>
  </view>
</view>