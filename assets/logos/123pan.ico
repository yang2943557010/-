<script src="https://statics.123pan.com/static/js/service-worker-register.js" defer></script>
<script src="https://statics.123pan.com/static/js/video-loader.js" defer></script>

<!-- 初始化 -->
<script>
    window.slotbydup = window.slotbydup || []
    window.aplus_queue = window.aplus_queue || []
</script>

<!-- 埋点脚本 - 首屏渲染后再加载，避免阻塞 -->
<script>
    // 等待首屏渲染完成后再加载埋点脚本
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => {
        loadAnalytics()
      }, { timeout: 3000 })
    } else {
      // 降级方案：等待 load 事件后 1 秒加载
      window.addEventListener('load', () => {
        setTimeout(loadAnalytics, 1000)
      })
    }

    function loadAnalytics() {
      const scripts = [
    'https://statics.123pan.com/static/js/analytics.js',
    'https://statics.123pan.com/static/js/aplus-config.js',
  ]
      scripts.forEach(src => {
        const script = document.createElement('script')
        script.src = src
        script.async = true
        document.body.appendChild(script)
      })
    }
</script>
