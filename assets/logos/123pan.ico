<!-- 滑块验证UI -->
<div id="sliderMask" style="width: 100%;height: 100vh;z-index: 9999;overflow: hidden;display: none;flex-direction: row;align-items: center;justify-content: center;position:fixed;left: 0;top:0;background: #ccc;opacity: 0.3;"></div>
<div id="sliderSpan"
     style="background: #fff;width: 352px;height: 348px;position:fixed;left:50%;top:50%;transform: translate(-50%, -50%);display: none;flex-direction: column;z-index:9999991;padding: 24px;box-shadow: 0px 4px 60px 0px rgba(0,0,0,0.1);border-radius: 20px 20px 20px 20px;">
    <div style="display: flex;flex-direction: row;align-items: center;justify-content: space-between">
        <span style="font-family: Microsoft YaHei UI, Microsoft YaHei UI;font-weight: bold;font-size: 18px;color: #1B1F35;line-height: 26px;">滑块验证</span>
        <div id="sliderSpanClose">
            <svg class="icon" aria-hidden="true" style="font-size: 16px;color: #1B1F35;cursor: pointer">
                <use xlink:href="#general_close_16_1"></use>
            </svg>
        </div>
    </div>
    <div style="display: flex;flex-direction: column;align-items: center;justify-content: center;margin-top: 20px;gap: 24px">
        <div>
            <img style="width: 352px;height: 218px" src="https://statics.123pan.com/static/slideraliv2.png" alt="">
        </div>
        <div id="nc"></div>
    </div>
</div>

